function addParcelaRow(){_nParcelas++;document.getElementById('parcelas-form').innerHTML+=parcelaRowHtml(_nParcelas-1);}

function renderFin(){
  db.collection('financeiro').onSnapshot(snap=>{
    let total=0,rec=0,arec=0,atr=0;
    snap.docs.forEach(d=>{
      const f=d.data();
      total+=f.total||0;
      (f.parcelas||[]).forEach(p=>{
        if(p.status==='Pago')rec+=p.val;
        else if(isPast(p.venc))atr+=p.val;
        else arec+=p.val;
      });
    });
    document.getElementById('fin-total').textContent=fmtR(total);
    document.getElementById('fin-rec').textContent=fmtR(rec);
    document.getElementById('fin-arec').textContent=fmtR(arec);
    document.getElementById('fin-atr').textContent=fmtR(atr);

    document.getElementById('fin-content').innerHTML=snap.empty
      ?'<div class="empty"><div class="empty-title">Nenhum registro financeiro</div></div>'
      :snap.docs.map(d=>{
        const f=d.data();
        const proj=_projetos.find(p=>p.id===f.projId);
        const pago=(f.parcelas||[]).filter(p=>p.status==='Pago').reduce((s,p)=>s+p.val,0);
        return`<div class="tbox" style="margin-bottom:12px">
          <div class="tbox-hdr">
            <div><div class="tbox-title">${proj?.nome||f.projId}</div>
              <div style="font-size:12px;color:var(--text3)">Total: ${fmtR(f.total)} · Recebido: ${fmtR(pago)}</div>
            </div>
          </div>
          ${(f.parcelas||[]).map((p,i)=>`<div class="parcela-row" style="padding:8px 18px">
            <span style="font-family:var(--mono);font-size:11px;color:var(--text3);min-width:20px">${p.n}</span>
            <span style="flex:1">${p.desc}</span>
            <span style="font-weight:600">${fmtR(p.val)}</span>
            <span>Venc: ${fmt(p.venc)}</span>
            ${sBadge(p.status)}
            <button class="btn btn-ghost btn-xs" onclick="toggleParcelaFin('${d.id}',${i})">${p.status==='Pago'?'↩':'✓ Pago'}</button>
          </div>`).join('')}
        </div>`;
      }).join('');
  });
}

async function toggleParcelaFin(docId,idx){
  const d=await db.collection('financeiro').doc(docId).get();
  const parcelas=[...(d.data().parcelas||[])];
  parcelas[idx]={...parcelas[idx],status:parcelas[idx].status==='Pago'?'A receber':'Pago',updatedBy:myName()};
  await db.collection('financeiro').doc(docId).update({parcelas,updatedBy:myName(),updatedAt:firebase.firestore.FieldValue.serverTimestamp()});
  await logAudit('atualizou parcela','financeiro',docId,`Parcela ${idx+1}`);
}

async function salvarFin(){
  const id=document.getElementById('fin-id').value;
  const projId=document.getElementById('fin-proj').value;
  const total=parseFloat(document.getElementById('fin-total-val').value)||0;
  const parcelas=[];
  for(let i=0;i<_nParcelas;i++){
    const desc=document.getElementById('pc-desc-'+i)?.value;
    const val=document.getElementById('pc-val-'+i)?.value;
    if(desc||val) parcelas.push({n:i+1,desc:desc||'',val:parseFloat(val)||0,venc:document.getElementById('pc-venc-'+i)?.value||'',status:document.getElementById('pc-st-'+i)?.value||'A receber'});
  }
  if(!projId){alert('Selecione o projeto');return;}
  const obj={projId,total,parcelas,updatedBy:myName(),updatedAt:firebase.firestore.FieldValue.serverTimestamp()};
  const existing=await db.collection('financeiro').where('projId','==',projId).get();
  if(existing.empty){obj.createdBy=myName();obj.createdAt=firebase.firestore.FieldValue.serverTimestamp();await db.collection('financeiro').add(obj);}
  else await db.collection('financeiro').doc(existing.docs[0].id).update(obj);
  await logAudit('registrou financeiro','financeiro',projId);
  closeM('m-fin');
}

