async function salvarDados(){
  const dados={
    nome:document.getElementById('de-nome').value,
    cnpj:document.getElementById('de-cnpj').value,
    cau:document.getElementById('de-cau').value,
    end:document.getElementById('de-end').value,
    tel:document.getElementById('de-tel').value,
    email:document.getElementById('de-email').value,
    ig:document.getElementById('de-ig').value,
    pix:document.getElementById('de-pix').value,
