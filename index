async function atualizarPct(id, curPct) {
  const novoPct = prompt('Novo progresso (0-100):', curPct);
  if (novoPct === null) return;
  const pct = Math.min(100, Math.max(0, parseInt(novoPct)||0));
  await db.collection('projetos').doc(id).update({pct, updatedBy: myName(), updatedAt: firebase.firestore.FieldValue.serverTimestamp()});
  await logAudit('atualizou progresso', 'projetos', id, `${pct}%`);
  abrirProj(id);
}

