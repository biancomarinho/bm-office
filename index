<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BM Office · Bianco Marinho</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- FIREBASE SDK -->
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>

<style>
:root{
  --bg:#fafaf8;--bg2:#f4f3f0;--bg3:#eeede9;--bg4:#e8e6e1;
  --border:#e2e0db;--border2:#d4d1ca;
  --text:#1c1b18;--text2:#6b6860;--text3:#a09d97;
  --acc:#2d5be3;--acc-l:#eaeffd;--acc-h:#1a3fc4;
  --green:#2a7a45;--green-l:#e6f5ec;
  --amber:#8a6000;--amber-l:#fdf4d7;
  --red:#b03030;--red-l:#fdeaea;
  --purple:#5c3a9e;--purple-l:#f0eafd;
  --teal:#1a6b7a;--teal-l:#e3f4f7;
  --orange:#b85c00;--orange-l:#fef0e0;
  --sw:252px;--font:'Outfit',sans-serif;--mono:'JetBrains Mono',monospace;
  --r:8px;--r2:12px;--r3:16px;
  --sh:0 1px 3px rgba(0,0,0,.05),0 1px 2px rgba(0,0,0,.04);
  --sh2:0 4px 16px rgba(0,0,0,.08);--sh3:0 8px 32px rgba(0,0,0,.12);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:var(--font);background:var(--bg);color:var(--text);font-size:14px}
body{display:flex;overflow:hidden}

/* ── AUTH SCREEN ── */
.auth-screen{position:fixed;inset:0;background:var(--bg2);z-index:999;display:flex;align-items:center;justify-content:center;padding:20px}
.auth-box{background:#fff;border:1px solid var(--border);border-radius:var(--r3);padding:36px 40px;width:100%;max-width:400px;box-shadow:var(--sh3)}
.auth-logo{display:flex;align-items:center;gap:12px;margin-bottom:28px;justify-content:center}
.auth-mark{width:44px;height:44px;background:var(--acc);border-radius:11px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:15px;font-weight:500;color:#fff}
.auth-title{font-size:22px;font-weight:700;color:var(--text)}
.auth-sub{font-size:12px;color:var(--text3);text-align:center;margin-top:3px}
.auth-form{margin-top:8px}
.auth-err{background:var(--red-l);color:var(--red);padding:9px 12px;border-radius:var(--r);font-size:12px;margin-bottom:12px;display:none}
.auth-err.show{display:block}

/* ── SIDEBAR ── */
.sb{width:var(--sw);background:#fff;border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;height:100vh;overflow-y:auto;overflow-x:hidden}
.sb::-webkit-scrollbar{width:3px}.sb::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
.sb-logo{padding:18px 14px 10px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
.sb-logo-mark{width:34px;height:34px;background:var(--acc);border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:13px;font-weight:500;color:#fff;flex-shrink:0}
.sb-logo-text{font-size:15px;font-weight:600;letter-spacing:-.3px}
.sb-logo-sub{font-size:11px;color:var(--text3)}
.sb-sec{padding:14px 10px 4px;font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.08em}
.sb-item{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:7px;cursor:pointer;font-size:13.5px;color:var(--text2);font-weight:400;margin:1px 6px;transition:all .1s;position:relative}
.sb-item:hover{background:var(--bg2);color:var(--text)}
.sb-item.on{background:var(--acc-l);color:var(--acc);font-weight:500}
.sb-item .ico{font-size:15px;width:20px;text-align:center;flex-shrink:0}
.sb-badge{margin-left:auto;background:var(--red-l);color:var(--red);font-size:10px;font-weight:600;padding:1px 6px;border-radius:20px}
.sb-footer{margin-top:auto;padding:10px 6px 14px;border-top:1px solid var(--border)}
.sb-user{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;cursor:pointer;transition:background .1s}
.sb-user:hover{background:var(--bg2)}
.avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0;color:#fff}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden}
.topbar{background:#fff;border-bottom:1px solid var(--border);height:52px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.topbar-left{display:flex;align-items:center;gap:10px}
.topbar-title{font-size:16px;font-weight:600}
.topbar-right{display:flex;align-items:center;gap:8px}
.content{flex:1;overflow-y:auto;padding:24px;background:var(--bg)}
.content::-webkit-scrollbar{width:4px}.content::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:7px;font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:var(--font);transition:all .12s;line-height:1}
.btn-primary{background:var(--acc);color:#fff}.btn-primary:hover{background:var(--acc-h)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border)}.btn-ghost:hover{background:var(--bg2);color:var(--text)}
.btn-danger{background:var(--red-l);color:var(--red)}
.btn-sm{padding:5px 11px;font-size:12px}
.btn-xs{padding:3px 8px;font-size:11px}

/* ── PAGE ── */
.page{display:none;animation:pgIn .15s ease}
.page.on{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* ── CARDS ── */
.stat-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:22px}
.stat{background:#fff;border:1px solid var(--border);border-radius:var(--r2);padding:16px 18px;cursor:pointer;transition:box-shadow .15s}
.stat:hover{box-shadow:var(--sh2)}
.stat-lbl{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.stat-val{font-size:28px;font-weight:700;line-height:1;color:var(--text)}

/* ── TABLE ── */
.tbox{background:#fff;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-bottom:18px}
.tbox-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.tbox-title{font-size:14px;font-weight:600}
table{width:100%;border-collapse:collapse}
th{padding:9px 14px;font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border);background:var(--bg);text-align:left}
td{padding:11px 14px;font-size:13.5px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tbody tr:hover td{background:var(--bg)}

/* ── BADGES ── */
.b{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500;white-space:nowrap}
.b-green{background:var(--green-l);color:var(--green)}
.b-amber{background:var(--amber-l);color:var(--amber)}
.b-red{background:var(--red-l);color:var(--red)}
.b-blue{background:var(--acc-l);color:var(--acc)}
.b-purple{background:var(--purple-l);color:var(--purple)}
.b-teal{background:var(--teal-l);color:var(--teal)}
.b-orange{background:var(--orange-l);color:var(--orange)}
.b-gray{background:var(--bg3);color:var(--text2)}

/* ── PROGRESS ── */
.prog-wrap{height:5px;background:var(--bg3);border-radius:5px;overflow:hidden;margin-top:4px}
.prog-fill{height:100%;background:var(--acc);border-radius:5px;transition:width .3s}

/* ── MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.28);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.overlay.on{display:flex}
.modal{background:#fff;border-radius:var(--r3);box-shadow:var(--sh3);width:100%;max-width:580px;max-height:92vh;overflow-y:auto;animation:modIn .15s ease}
.modal.wide{max-width:780px}
@keyframes modIn{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:none}}
.modal-hdr{padding:20px 22px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:16px;font-weight:600}
.mclose{background:none;border:none;cursor:pointer;font-size:18px;color:var(--text3);padding:4px 7px;border-radius:5px;line-height:1}
.mclose:hover{background:var(--bg2)}
.modal-body{padding:20px 22px}
.modal-footer{padding:14px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px}

/* ── FORMS ── */
.fg{margin-bottom:15px}
.fl{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:5px}
.fi,.fs,.fta{width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:7px;font-size:13.5px;font-family:var(--font);color:var(--text);background:#fff;outline:none;transition:border .12s}
.fi:focus,.fs:focus,.fta:focus{border-color:var(--acc)}
.fta{resize:vertical;min-height:72px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* ── KANBAN ── */
.kanban{display:flex;gap:14px;overflow-x:auto;padding-bottom:8px}
.kcol{background:var(--bg2);border-radius:var(--r2);min-width:240px;flex-shrink:0;border:1px solid var(--border);overflow:hidden}
.kcol-hdr{padding:11px 14px;font-size:12px;font-weight:600;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.kcol-count{background:var(--bg3);color:var(--text3);font-size:10px;font-weight:600;padding:1px 7px;border-radius:20px}
.kcol-body{padding:8px}
.kcard{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;margin-bottom:7px;cursor:pointer;box-shadow:var(--sh);transition:box-shadow .12s}
.kcard:hover{box-shadow:var(--sh2)}
.kcard-title{font-size:13px;font-weight:500;margin-bottom:5px;line-height:1.35}
.kcard-meta{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:6px;flex-wrap:wrap}

/* ── CHECKLIST ── */
.ck-group{background:#fff;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-bottom:12px}
.ck-group-hdr{padding:12px 16px;background:var(--bg);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ck-group-title{font-size:13px;font-weight:600}
.ck-row{display:flex;align-items:flex-start;gap:10px;padding:9px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s}
.ck-row:last-child{border-bottom:none}
.ck-row:hover{background:var(--bg)}
.ck-row.done{opacity:.5}
.ck-box{width:16px;height:16px;border:1.5px solid var(--border2);border-radius:3px;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:10px}
.ck-row.done .ck-box{background:var(--green);border-color:var(--green);color:#fff}
.ck-text{font-size:13px;flex:1}
.ck-row.done .ck-text{text-decoration:line-through;color:var(--text3)}
.ck-edited{font-size:10px;color:var(--text3);margin-top:1px}

/* ── CHAT ── */
.chat-wrap{display:flex;height:calc(100vh - 100px);background:#fff;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.chat-sidebar{width:220px;border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.chat-sb-hdr{padding:14px 14px 10px;font-size:13px;font-weight:600;border-bottom:1px solid var(--border)}
.chat-channel{padding:8px 12px;cursor:pointer;font-size:13px;color:var(--text2);border-radius:6px;margin:2px 6px;display:flex;align-items:center;gap:8px;transition:background .1s}
.chat-channel:hover{background:var(--bg2)}
.chat-channel.on{background:var(--acc-l);color:var(--acc);font-weight:500}
.chat-channel .unread{margin-left:auto;background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:20px}
.chat-main{flex:1;display:flex;flex-direction:column;min-width:0}
.chat-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.chat-hdr-title{font-size:14px;font-weight:600}
.chat-hdr-sub{font-size:11px;color:var(--text3)}
.chat-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px}
.chat-messages::-webkit-scrollbar{width:4px}.chat-messages::-webkit-scrollbar-thumb{background:var(--border2)}
.msg{display:flex;align-items:flex-end;gap:8px;max-width:75%}
.msg.mine{flex-direction:row-reverse;align-self:flex-end}
.msg-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0;color:#fff}
.msg-bubble{background:var(--bg2);border-radius:12px 12px 12px 3px;padding:9px 13px;font-size:13px;line-height:1.45;border:1px solid var(--border)}
.msg.mine .msg-bubble{background:var(--acc-l);border-color:var(--acc-l);border-radius:12px 12px 3px 12px;color:var(--acc-h)}
.msg-meta{font-size:10px;color:var(--text3);margin-top:3px;text-align:right}
.msg.mine .msg-meta{text-align:left}
.msg-sender{font-size:11px;font-weight:600;color:var(--text2);margin-bottom:2px}
.chat-input-wrap{padding:12px 16px;border-top:1px solid var(--border);display:flex;gap:8px}
.chat-input{flex:1;padding:9px 14px;border:1px solid var(--border);border-radius:22px;font-size:13.5px;font-family:var(--font);color:var(--text);background:#fff;outline:none;transition:border .12s}
.chat-input:focus{border-color:var(--acc)}
.chat-send{background:var(--acc);color:#fff;border:none;border-radius:50%;width:36px;height:36px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .12s}
.chat-send:hover{background:var(--acc-h)}

/* ── AUDIT ── */
.audit-row{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);font-size:12px}
.audit-row:last-child{border-bottom:none}
.audit-ico{font-size:16px;flex-shrink:0;margin-top:1px}
.audit-txt{flex:1;color:var(--text2)}
.audit-time{color:var(--text3);font-size:11px;white-space:nowrap}

/* ── PROJECT HERO ── */
.proj-hero{background:#fff;border:1px solid var(--border);border-radius:var(--r2);padding:20px 22px;margin-bottom:16px}
.proj-hero-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;gap:12px;flex-wrap:wrap}
.proj-title{font-size:20px;font-weight:700}
.proj-meta{font-size:12px;color:var(--text3);margin-top:3px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.proj-prog-bar{flex:1;height:7px;background:var(--bg3);border-radius:7px;overflow:hidden}
.proj-prog-fill{height:100%;background:var(--acc);border-radius:7px}
.proj-prog-pct{font-size:13px;font-weight:700;color:var(--acc);min-width:38px;text-align:right}

/* ── TABS ── */
.tabs{display:flex;gap:2px;background:var(--bg3);border-radius:9px;padding:3px;margin-bottom:18px;width:fit-content}
.tab{padding:5px 14px;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text2);font-family:var(--font);transition:all .12s;white-space:nowrap}
.tab.on{background:#fff;color:var(--text);box-shadow:var(--sh)}

/* ── SEC HDR ── */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px}
.sec-title{font-size:18px;font-weight:700}
.sec-sub{font-size:13px;color:var(--text3);margin-top:2px}

/* ── CALENDAR ── */
.cal-wrap{background:#fff;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr)}
.cal-dh{padding:8px 0;text-align:center;font-size:11px;font-weight:600;color:var(--text3);background:var(--bg);border-bottom:1px solid var(--border)}
.cal-cell{min-height:80px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:5px;cursor:pointer;transition:background .1s}
.cal-cell:nth-child(7n){border-right:none}
.cal-cell:hover{background:var(--bg)}
.cal-cell.today{background:var(--acc-l)}
.cal-cell.other{opacity:.3;background:var(--bg)}
.cal-dn{font-size:12px;font-weight:500;color:var(--text2);margin-bottom:3px}
.cal-cell.today .cal-dn{background:var(--acc);color:#fff;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px}
.cal-ev{font-size:10px;padding:2px 5px;border-radius:3px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── EMPTY ── */
.empty{text-align:center;padding:44px 20px;color:var(--text3)}
.empty-ico{font-size:40px;margin-bottom:12px}
.empty-title{font-size:15px;font-weight:600;color:var(--text2);margin-bottom:5px}

/* ── LOADING ── */
.loading{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--text3);gap:10px;font-size:13px}
.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--acc);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── ONLINE INDICATOR ── */
.online-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0}
.offline-dot{width:8px;height:8px;border-radius:50%;background:var(--border2);flex-shrink:0}

/* ── MOBILE ── */
.mob-toggle{display:none;background:none;border:none;font-size:22px;cursor:pointer;padding:6px}
@media(max-width:800px){
  .sb{position:fixed;top:0;left:0;z-index:200;transform:translateX(-100%);transition:transform .2s}
  .sb.open{transform:none}
  .main{margin-left:0}
  .mob-toggle{display:block}
  .content{padding:16px}
  .frow{grid-template-columns:1fr}
  .chat-sidebar{display:none}
}

/* ── FINANCEIRO ── */
.parcela-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.parcela-row:last-child{border-bottom:none}

/* ── POST STATUS ── */
.post-plat-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
</style>
</head>
<body>

<!-- ══ AUTH SCREEN ══ -->
<div class="auth-screen" id="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="auth-mark">BM</div>
    </div>
    <div style="text-align:center;margin-bottom:24px">
      <div class="auth-title">BM Office</div>
      <div class="auth-sub">Bianco Marinho Arquitetura, Interiores e Engenharia</div>
    </div>
    <div class="auth-err" id="auth-err"></div>
    <div class="auth-form">
      <div class="fg"><label class="fl">Email</label><input class="fi" type="email" id="login-email" placeholder="seu@email.com" autocomplete="email"></div>
      <div class="fg"><label class="fl">Senha</label><input class="fi" type="password" id="login-senha" placeholder="••••••••" autocomplete="current-password" onkeydown="if(event.key==='Enter')doLogin()"></div>
      <button class="btn btn-primary" style="width:100%;justify-content:center;padding:10px" onclick="doLogin()" id="login-btn">Entrar</button>
    </div>
    <div style="font-size:11px;color:var(--text3);text-align:center;margin-top:16px">BM Office · Sistema interno do escritório</div>
  </div>
</div>

<!-- ══ SIDEBAR ══ -->
<nav class="sb" id="sb">
  <div class="sb-logo">
    <div class="sb-logo-mark">BM</div>
    <div><div class="sb-logo-text">BM Office</div><div class="sb-logo-sub">Bianco Marinho Arq.</div></div>
  </div>

  <div class="sb-sec">Principal</div>
  <div class="sb-item on" onclick="nav('dashboard')"><span class="ico">🏠</span>Dashboard</div>
  <div class="sb-item" onclick="nav('projetos')"><span class="ico">📁</span>Projetos</div>
  <div class="sb-item" onclick="nav('tarefas')"><span class="ico">✅</span>Tarefas<span class="sb-badge" id="badge-tar" style="display:none">0</span></div>
