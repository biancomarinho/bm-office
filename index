  const [ps, cs] = await Promise.all([
    db.collection('projetos').orderBy('cod').get(),
    db.collection('clientes').orderBy('nome').get()
  ]);
  _projetos = ps.docs.map(d=>({id:d.id,...d.data()}));
  _clientes = cs.docs.map(d=>({id:d.id,...d.data()}));
  refreshSels();
}

function refreshSels() {
  const projOpts = '<option value="">—</option>' + _projetos.map(p=>`<option value="${p.id}">${p.cod} — ${p.nome}</option>`).join('');
  const cliOpts  = '<option value="">—</option>' + _clientes.map(c=>`<option>${c.nome}</option>`).join('');
  ['tar-proj','ev-proj','sel-cp-proj'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=id==='sel-cp-proj'?'<option value="">Selecione...</option>'+_projetos.map(p=>`<option value="${p.id}">${p.cod} — ${p.nome}</option>`).join(''):projOpts;});
  ['proj-cli','prop-cli','fin-proj'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=cliOpts;});
