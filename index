let _chatChannel='geral';
let _chatUnsub=null;

function renderChat() {
  switchChannel('geral');
}

function switchChannel(channelId, label) {
  _chatChannel=channelId;
  document.querySelectorAll('.chat-channel').forEach(c=>c.classList.remove('on'));
  const el=document.getElementById('ch-'+channelId);
  if(el) el.classList.add('on');
  const title=channelId==='geral'?'# geral':`# ${label||channelId}`;
  document.getElementById('chat-channel-title').textContent=title;
  document.getElementById('chat-channel-sub').textContent=channelId==='geral'?'Canal geral da equipe':`Canal do projeto ${label||channelId}`;
  if(_chatUnsub) _chatUnsub();
  const msgsEl=document.getElementById('chat-messages');
  msgsEl.innerHTML='<div class="loading"><div class="spinner"></div>Carregando...</div>';
  _chatUnsub=db.collection('chat').doc(channelId).collection('messages').orderBy('ts').limitToLast(50).onSnapshot(snap=>{
    const myEmail=CUR?.email||'';
    msgsEl.innerHTML=snap.docs.map(d=>{
      const m=d.data();
      const mine=m.email===myEmail;
      const ts=m.ts?.toDate();
      const timeStr=ts?ts.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}):'';
      const color=USER_COLORS[m.email]||'#888';
      const ini=(USER_NAMES[m.email]||m.name||'?').slice(0,2).toUpperCase();
      return`<div class="msg ${mine?'mine':''}" style="max-width:75%">
        <div class="msg-avatar" style="background:${color}">${ini}</div>
        <div>
          ${!mine?`<div class="msg-sender">${m.name||m.email}</div>`:''}
          <div class="msg-bubble">${m.text}</div>
          <div class="msg-meta">${timeStr}</div>
        </div>
      </div>`;
    }).join('');
    msgsEl.scrollTop=msgsEl.scrollHeight;
  });
}

async function sendMsg() {
  const input=document.getElementById('chat-input');
  const text=input.value.trim();
  if(!text||!CUR) return;
  input.value='';
  await db.collection('chat').doc(_chatChannel).collection('messages').add({
    text,
    email:CUR.email,
    name:myName(),
    color:myColor(),
    ts:firebase.firestore.FieldValue.serverTimestamp(),
  });
  // Update unread for others (simplified)
  await db.collection('chat').doc(_chatChannel).set({lastMsg:text,lastBy:myName(),lastAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});
}

