  };
  if(!p.titulo){alert('Título obrigatório');return;}
  const ref=id?db.collection('posts').doc(id):db.collection('posts').doc();
  if(!id){p.createdBy=myName();p.createdAt=firebase.firestore.FieldValue.serverTimestamp();}
  await ref.set(p,{merge:true});
  await logAudit(id?'editou post':'criou post','posts',ref.id,p.titulo);
  closeM('m-post');
}

