    const dados=d.exists?d.data():{nome:'Bianco Marinho Arquitetura, Interiores e Engenharia'};
    const campos=[['Nome',dados.nome],['CNPJ',dados.cnpj],['CAU/CREA',dados.cau],['Endereço',dados.end],['Telefone',dados.tel],['Email',dados.email],['Instagram',dados.ig],['PIX',dados.pix],['Missão',dados.missao]];
    document.getElementById('dados-view').innerHTML=campos.filter(([,v])=>v).map(([l,v])=>`
      <div style="display:flex;align-items:flex-start;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)">
        <span style="font-size:12px;font-weight:500;color:var(--text3);min-width:160px">${l}</span>
