  const ch=document.getElementById('chat-proj-channels');
  if(ch) ch.innerHTML=_projetos.slice(0,6).map(p=>`<div class="chat-channel" id="ch-${p.id}" onclick="switchChannel('${p.id}','${p.cod}')"><span>#</span><span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.cod}</span></div>`).join('');
}

