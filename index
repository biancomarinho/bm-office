// CALENDÁRIO
// ══════════════════════════════════════════════════════
let cY=new Date().getFullYear(),cM=new Date().getMonth();
const MESES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const DIAS=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

function renderCal() {
  document.getElementById('cal-lbl').textContent=`${MESES[cM]} ${cY}`;
  document.getElementById('cal-dhs').innerHTML=DIAS.map(d=>`<div class="cal-dh">${d}</div>`).join('');
  const fd=new Date(cY,cM,1).getDay();
  const dim=new Date(cY,cM+1,0).getDate();
  const dip=new Date(cY,cM,0).getDate();
  let cells='';
  for(let i=fd-1;i>=0;i--)cells+=`<div class="cal-cell other"><div class="cal-dn">${dip-i}</div></div>`;
  for(let d=1;d<=dim;d++){
    const ds=`${cY}-${String(cM+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isTd=ds===today();
    cells+=`<div class="cal-cell${isTd?' today':''}" id="cal-${ds}"><div class="cal-dn">${isTd?`<div style="background:var(--acc);color:#fff;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px">${d}</div>`:d}</div></div>`;
  }
  const rem=42-fd-dim;
  for(let d=1;d<=rem;d++)cells+=`<div class="cal-cell other"><div class="cal-dn">${d}</div></div>`;
  document.getElementById('cal-cells').innerHTML=cells;

  // Load events
  const start=`${cY}-${String(cM+1).padStart(2,'0')}-01`;
  const end  =`${cY}-${String(cM+1).padStart(2,'0')}-${String(dim).padStart(2,'0')}`;
  db.collection('eventos').where('data','>=',start).where('data','<=',end).onSnapshot(snap=>{
    snap.docs.forEach(d=>{
      const e=d.data();
      const cell=document.getElementById('cal-'+e.data);
      if(cell){
        const ev=document.createElement('div');
        ev.className='cal-ev';
        ev.style.background=(TIPO_CAL_COL[e.tipo]||'#666')+'22';
        ev.style.color=TIPO_CAL_COL[e.tipo]||'#666';
        ev.textContent=e.titulo;
        cell.appendChild(ev);
      }
    });
    // Próximos eventos
    const prox=snap.docs.filter(d=>d.data().data>=today()).sort((a,b)=>a.data().data.localeCompare(b.data().data)).slice(0,8);
    document.getElementById('cal-list').innerHTML=prox.length===0
      ?'<div class="empty"><div class="empty-title">Nenhum evento futuro</div></div>'
      :prox.map(d=>{const e=d.data();return`
        <div style="display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border)">
          <div style="text-align:center;min-width:44px;background:var(--bg);border-radius:var(--r);padding:6px">
            <div style="font-size:18px;font-weight:700;color:var(--acc)">${e.data.split('-')[2]}</div>
            <div style="font-size:10px;color:var(--text3)">${MESES[+e.data.split('-')[1]-1].slice(0,3)}</div>
          </div>
          <div style="flex:1">
            <div style="font-size:13px;font-weight:500">${e.titulo}</div>
            <div style="font-size:11px;color:var(--text3)">${e.hora||''} ${e.partic?'· '+e.partic:''} ${e.local?'· '+e.local:''}</div>
            ${e.createdBy?`<div style="font-size:10px;color:var(--text3)">por ${e.createdBy}</div>`:''}
          </div>
          <button class="btn btn-danger btn-xs" onclick="deletarEvento('${d.id}')">✕</button>
        </div>`}).join('');
  });
}

function calPrev(){cM--;if(cM<0){cM=11;cY--;}renderCal();}
