async function toggleCk(projId, groupId, itemIdx, itemName) {
  const docRef = db.collection('projetos').doc(projId);
  const d = await docRef.get();
  const ck = d.data().checklist || {};
  if (!ck[groupId]) ck[groupId] = {};
  const cur = ck[groupId][itemIdx] || {};
  const newVal = !cur.done;
  ck[groupId][itemIdx] = {
    done: newVal,
    by: newVal ? myName() : null,
    at: newVal ? firebase.firestore.Timestamp.now() : null
  };
  await docRef.update({ checklist: ck, updatedBy: myName(), updatedAt: firebase.firestore.FieldValue.serverTimestamp() });
  await logAudit(newVal?'concluiu etapa':'reabriu etapa', 'projetos', projId, itemName);
  projTab('checklist', document.querySelector('#pg-proj-detalhe .tab.on'));
}

function editarEtapa(projId, groupId, label) {
  db.collection('projetos').doc(projId).get().then(d=>{
    const ep=(d.data().etapas||{})[groupId]||{};
    document.getElementById('etapa-proj-id').value=projId;
    document.getElementById('etapa-group-id').value=groupId;
    document.getElementById('etapa-label-txt').textContent=label;
    document.getElementById('m-etapa-title').textContent='Etapa: '+label.split('—')[1]?.trim()||label;
    document.getElementById('etapa-resp').value=ep.resp||'';
    document.getElementById('etapa-status').value=ep.status||'A iniciar';
    document.getElementById('etapa-hest').value=ep.hEst||'';
    document.getElementById('etapa-hreal').value=ep.hReal||'';
    document.getElementById('etapa-ini').value=ep.ini||'';
    document.getElementById('etapa-fim').value=ep.fim||'';
    openM('m-etapa');
  });
}

async function salvarEtapa() {
  const projId=document.getElementById('etapa-proj-id').value;
  const groupId=document.getElementById('etapa-group-id').value;
  const ep={
    resp:   document.getElementById('etapa-resp').value,
    status: document.getElementById('etapa-status').value,
    hEst:   parseFloat(document.getElementById('etapa-hest').value)||0,
    hReal:  parseFloat(document.getElementById('etapa-hreal').value)||0,
    ini:    document.getElementById('etapa-ini').value,
    fim:    document.getElementById('etapa-fim').value,
    updatedBy: myName(),
    updatedAt: firebase.firestore.FieldValue.serverTimestamp(),
  };
  await db.collection('projetos').doc(projId).update({
    [`etapas.${groupId}`]: ep,
    updatedBy: myName(),
