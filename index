function initApp(){
  document.getElementById('tdate').textContent=new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'numeric',month:'short'});
  loadSelects().then(()=>{renderDash();});
  // Financeiro modal
  document.querySelector('[onclick="openM(\'m-fin\')"]')?.addEventListener('click',()=>{
    _nParcelas=3;
    let html='';for(let i=0;i<_nParcelas;i++)html+=parcelaRowHtml(i);
    document.getElementById('parcelas-form').innerHTML=html;
  });
  // Dados modal
  document.querySelector('[onclick="openM(\'m-dados\')"]')?.addEventListener('click',()=>{
    db.collection('config').doc('escritorio').get().then(d=>{
      if(!d.exists)return;
      const dados=d.data();
      ['nome','cnpj','cau','end','tel','email','ig','pix','missao'].forEach(k=>{const el=document.getElementById('de-'+k);if(el)el.value=dados[k]||'';});
    });
  });
}
